# CodeBlox Environment Configuration
# Copy this file to .env and fill in your values

# Server port
PORT=3000

# API key for authenticating requests between CLI, server, and plugin
CODEBLOX_API_KEY=your-secret-api-key-here

# Default AI provider (google-ai, xiaomi-mimo, openclaude)
DEFAULT_PROVIDER=google-ai

# Default AI model
DEFAULT_MODEL=gemini-pro

# Default theme (black or white)
DEFAULT_THEME=black
